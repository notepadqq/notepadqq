#!/bin/sh

set -u

test -n "${CMAKE:-}" || CMAKE="cmake"
test -n "${CXX:-}" || CXX="c++"
test -n "${MAKE:-}" || MAKE="$(command -v gmake 2>/dev/null || command -v make 2>/dev/null || printf '%s' make)"
test -n "${TMPDIR:-}" || TMPDIR="$PWD"

PREFIX=""
PRESET=""
BUILD_TYPE="Release"
BUILD_DIR=""
CONFIGURED_BUILD_DIR=""
fail_on_missing="no"

errorExit() {
    printf '%s\n' "$1"
    test "${2:-0}" != "1" || fail_on_missing="yes"
    test "$fail_on_missing" != "yes" || exit 1
}

help() {
cat << EOF

Usage: ./configure [OPTION]... [VAR=VALUE]... [--cmake-args ARGS...]

Configures Notepadqq with CMake. Environment assignments such as CXX=clang++
are passed through to CMake in the usual way.

Defaults for the options are specified in brackets.

  -h, --help              display this help and exit

  --prefix PREFIX,
  --prefix=PREFIX         install files in PREFIX [preset default]

  -d, --debug             build in out/debug instead of out/release

  --preset PRESET,
  --preset=PRESET         use a CMake preset instead of the legacy out/release layout

  --build-dir DIR,
  --build-dir=DIR         configure an explicit build directory instead of a preset

  --fail-on-missing       return exit 1 if required tools are missing

  --cmake COMMAND,
  --cmake=COMMAND         specify cmake command [$CMAKE]
  --cmake-args ARGS       arguments to pass directly to cmake

Deprecated qmake options are accepted for compatibility and ignored:
  --qmake, --qmake=COMMAND, --qmake-args, --lrelease, --lrelease=COMMAND

Some influential environment variables:
  CMAKE       cmake command
  MAKE        make command, used for editor and extension asset staging
  CXX         C++ compiler
  LDFLAGS     linker flags
  CPPFLAGS    C/C++ preprocessor flags
  CXXFLAGS    C++ compiler flags

Examples:
  ./configure --prefix /usr
  ./configure -d
  ./configure --preset asan
  ./configure --build-dir out/cmake/local --cmake-args -DNQQ_BUILD_TESTS=OFF

EOF
}

check() {
    printf 'checking for %s... ' "$1"
    tool=$(basename "$2")
    if command -v "$tool" >/dev/null 2>&1; then
        command -v "$tool"
    else
        errorExit 'not found!' "$3"
    fi
}

check_cxx_functionality() {
    test_src="$TMPDIR/notepadqq-configure-test.cpp"
    test_bin="$TMPDIR/notepadqq-configure-test"

    rm -f "$test_src" "$test_bin"
    cat > "$test_src" << EOF
#include <iostream>

int main()
{
    std::cout << "Hello World!" << std::endl;
    return 0;
}
EOF

    printf 'checking whether c++ compiler builds test program... '
    "$CXX" -o "$test_bin" "$test_src" && printf 'ok\n' || {
        rm -f "$test_src" "$test_bin"
        errorExit 'error!' 1
    }

    printf 'checking whether c++ compiler supports -std=c++20... '
    rm -f "$test_bin"
    "$CXX" -std=c++20 -o "$test_bin" "$test_src" && printf 'ok\n' || {
        rm -f "$test_src" "$test_bin"
        errorExit 'error!' 1
    }

    printf 'checking whether compiled test program works... '
    "$test_bin" >/dev/null 2>&1 && printf 'ok\n' || {
        rm -f "$test_src" "$test_bin"
        errorExit 'error!' 1
    }

    rm -f "$test_src" "$test_bin"
}

write_makefile() {
    cat > Makefile << EOF
# Generated by ./configure. Edit CMakeLists.txt or CMakePresets.json instead.

.PHONY: all install clean test

all:
	"$CMAKE" --build "$CONFIGURED_BUILD_DIR"

install:
	"$CMAKE" --install "$CONFIGURED_BUILD_DIR"

clean:
	"$CMAKE" --build "$CONFIGURED_BUILD_DIR" --target clean

test:
	"$CMAKE" --build "$CONFIGURED_BUILD_DIR"
	ctest --test-dir "$CONFIGURED_BUILD_DIR" --output-on-failure
EOF
}

cmake_args=""
while [ "$#" -ge 1 ]; do
    key="$1"
    shift

    case "$key" in
        -h|--help)
            help
            exit 0
            ;;
        -d|--debug)
            BUILD_TYPE="Debug"
            ;;
        --prefix=*)
            PREFIX="${key#*=}"
            ;;
        --prefix)
            PREFIX="$1"
            shift
            ;;
        --preset=*)
            PRESET="${key#*=}"
            ;;
        --preset)
            PRESET="$1"
            shift
            ;;
        --build-dir=*)
            BUILD_DIR="${key#*=}"
            ;;
        --build-dir)
            BUILD_DIR="$1"
            shift
            ;;
        --fail-on-missing)
            fail_on_missing="yes"
            ;;
        --cmake=*)
            CMAKE="${key#*=}"
            ;;
        --cmake)
            CMAKE="$1"
            shift
            ;;
        --cmake-args)
            cmake_args="$*"
            break
            ;;
        --qmake|--qmake=*|--lrelease|--lrelease=*)
            test "$key" = "--qmake" -o "$key" = "--lrelease" && shift
            printf 'WARNING: %s is ignored by the CMake build.\n' "$key"
            ;;
        --qmake-args)
            printf 'WARNING: --qmake-args is ignored by the CMake build.\n'
            break
            ;;
        *=*)
            export "$key"
            ;;
        *)
            printf 'WARNING: Unknown option %s\n' "$key"
            ;;
    esac
done

check cmake "$CMAKE" 1
check c++ "$CXX" 1
check_cxx_functionality
check make "$MAKE" 1
check pkg-config pkg-config 1

if [ -n "$PREFIX" ]; then
    cmake_args="$cmake_args -DCMAKE_INSTALL_PREFIX=$PREFIX"
fi

if [ -z "$PRESET" ] && [ -z "$BUILD_DIR" ]; then
    if [ "$BUILD_TYPE" = "Debug" ]; then
        BUILD_DIR="out/debug"
    else
        BUILD_DIR="out/release"
    fi
fi

if [ -n "$BUILD_DIR" ]; then
    CONFIGURED_BUILD_DIR="$BUILD_DIR"
    printf 'configuring CMake build directory %s...\n' "$BUILD_DIR"
    # shellcheck disable=SC2086
    "$CMAKE" -S . -B "$BUILD_DIR" -DCMAKE_BUILD_TYPE="$BUILD_TYPE" -DCMAKE_CXX_COMPILER="$CXX" -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DNQQ_BUILD_TESTS=ON $cmake_args || errorExit 'CMake configure failed!' 1
else
    CONFIGURED_BUILD_DIR="out/cmake/$PRESET"
    printf 'configuring CMake preset %s...\n' "$PRESET"
    # shellcheck disable=SC2086
    "$CMAKE" --preset "$PRESET" -DCMAKE_CXX_COMPILER="$CXX" $cmake_args || errorExit 'CMake configure failed!' 1
fi

write_makefile
printf 'done\n'
